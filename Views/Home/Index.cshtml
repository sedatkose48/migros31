@{
    ViewData["Title"] = "Migros Stratejik Analiz";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /* CSS kodların (Daha önce yaptığımız premium, karanlık tema, balık kılçığı ve rice stilleri) aynen korundu. */
    .section-card { background: rgba(15, 23, 42, 0.9); backdrop-filter: blur(12px); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 28px; padding: 3.5rem; margin-bottom: 3.5rem; transition: all 0.3s ease; position: relative; }
    .section-card:hover { border-color: var(--migros-orange); transform: translateY(-5px); }
    .section-title { font-weight: 800; color: white !important; letter-spacing: -0.02em; }
    .section-card p.text-muted { color: #f1f5f9 !important; font-size: 0.95rem; line-height: 1.8; }
    .badge-step { background: rgba(255, 130, 0, 0.2); color: var(--migros-orange); padding: 0.6rem 1.2rem; border-radius: 10px; font-family: 'JetBrains Mono', monospace; font-size: 0.85rem; font-weight: 700; text-transform: uppercase; }
    .corporate-box { background: rgba(255, 255, 255, 0.05); border-left: 5px solid var(--migros-orange); padding: 2.5rem; border-radius: 0 20px 20px 0; transition: 0.3s; }
    .corporate-box:hover { background: rgba(255, 255, 255, 0.08); }
    .corporate-box h6 { color: white !important; }
    .corporate-box p { color: #f1f5f9 !important; font-size: 0.9rem; }
    .team-photo-container { position: relative; display: inline-block; transition: transform 0.4s ease; }
    .team-photo-large { width: 150px; height: 150px; border-radius: 50%; border: 4px solid var(--migros-orange); padding: 6px; object-fit: cover; background: #020617; }
    .team-member-card:hover .team-photo-container { transform: scale(1.1); }
    .team-name { color: white !important; font-weight: 700; }
    .team-role-badge { font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; color: var(--migros-orange); background: rgba(255,130,0,0.15); padding: 5px 15px; border-radius: 25px; display: inline-block; margin-top: 10px; }
    .swot-box-premium { background: rgba(15, 23, 42, 0.95); border: 1px solid rgba(255, 255, 255, 0.08); border-radius: 24px; padding: 2.8rem; height: 100%; transition: 0.3s; }
    .swot-box-premium:hover { background: rgba(255, 255, 255, 0.03); transform: translateY(-5px); border-color: rgba(255,255,255,0.15); }
    .swot-header { display: flex; align-items: center; gap: 1rem; margin-bottom: 2rem; border-bottom: 1px solid rgba(255,255,255,0.06); padding-bottom: 1rem; }
    .swot-header h5 { color: white !important; font-weight: 700; margin: 0; }
    .swot-icon-circle { width: 50px; height: 50px; border-radius: 14px; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; }
    .bg-success-soft { background: rgba(25, 135, 84, 0.2); } .bg-danger-soft { background: rgba(220, 53, 69, 0.2); } .bg-info-soft { background: rgba(13, 202, 240, 0.2); } .bg-warning-soft { background: rgba(255, 193, 7, 0.2); }
    .sw-list-premium { list-style: none; padding: 0; }
    .sw-list-premium li { color: white !important; font-size: 0.92rem; margin-bottom: 1.2rem; padding-left: 25px; position: relative; line-height: 1.7; }
    .sw-list-premium li::before { content: "•"; color: var(--migros-orange); position: absolute; left: 0; font-size: 1.6rem; line-height: 1.1; }
    .swot-score-badge { font-family: 'JetBrains Mono', monospace; font-size: 0.8rem; color: #f1f5f9; background: rgba(255,255,255,0.05); padding: 5px 12px; border-radius: 8px; border: 1px solid rgba(255,255,255,0.1); }
    .tows-card { background: rgba(15, 23, 42, 0.95); border-radius: 20px; padding: 2.5rem; height: 100%; border: 1px solid rgba(255, 255, 255, 0.08); transition: 0.3s; }
    .tows-card:hover { transform: translateY(-5px); border-color: rgba(255, 255, 255, 0.15); }
    .tows-tag { font-family: 'JetBrains Mono'; font-size: 0.7rem; padding: 4px 10px; border-radius: 6px; font-weight: 700; text-transform: uppercase; }
    .so-border { border-top: 4px solid #198754; } .st-border { border-top: 4px solid #0dcaf0; } .wo-border { border-top: 4px solid #ffc107; } .wt-border { border-top: 4px solid #dc3545; }
    .moscow-card { background: rgba(255, 255, 255, 0.03); border: 1px solid rgba(255, 255, 255, 0.08); border-radius: 20px; padding: 2rem; height: 100%; transition: 0.3s ease; text-align: center; }
    .moscow-card:hover { transform: scale(1.05); background: rgba(255, 255, 255, 0.06); }
    .moscow-icon { width: 50px; height: 50px; border-radius: 12px; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.5rem; font-size: 1.4rem; color: white; }
    .moscow-label { font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; font-weight: 700; text-transform: uppercase; margin-bottom: 1.5rem; letter-spacing: 1px; }
    .moscow-list { list-style: none; padding: 0; text-align: left; }
    .moscow-list li { color: #f1f5f9; font-size: 0.8rem; margin-bottom: 0.8rem; position: relative; padding-left: 18px; line-height: 1.4; }
    .moscow-list li::before { content: "•"; position: absolute; left: 0; color: var(--migros-orange); }
    .m-must { border-bottom: 4px solid #198754; } .m-should { border-bottom: 4px solid #0dcaf0; } .m-could { border-bottom: 4px solid #ffc107; } .m-wont { border-bottom: 4px solid #dc3545; }
    .table-rice-premium { width: 100%; border-collapse: separate; border-spacing: 0 10px; color: #ffffff !important; }
    .table-rice-premium thead th { font-family: 'JetBrains Mono', monospace; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 1px; color: var(--migros-orange) !important; padding: 1.5rem 1rem; border: none; background: rgba(255, 255, 255, 0.02); }
    .table-rice-premium tbody tr { background: rgba(255, 255, 255, 0.04); transition: all 0.3s ease; }
    .table-rice-premium tbody tr:hover { background: rgba(255, 255, 255, 0.08); transform: scale(1.005); }
    .table-rice-premium td { padding: 1.5rem 1rem; border: none; vertical-align: middle; }
    .rice-hypo-title { display: block; color: #ffffff !important; font-weight: 700; font-size: 1rem; margin-bottom: 4px; }
    .rice-hypo-desc { display: block; color: #94a3b8 !important; font-size: 0.8rem; line-height: 1.4; }
    .rice-value { display: block; font-weight: 600; color: #f1f5f9; }
    .rice-sublabel { display: block; font-size: 0.7rem; color: #64748b; margin-top: 2px; }
    .badge-rice-score { font-family: 'JetBrains Mono', monospace; font-size: 1rem; padding: 0.6rem 1.2rem; border-radius: 10px; box-shadow: 0 4px 10px rgba(0,0,0,0.3); }
    .fish-container { width: 100%; background: rgba(15, 23, 42, 0.4); border-radius: 30px; padding: 40px; display: flex; justify-content: center; border: 1px solid rgba(255, 255, 255, 0.05); overflow: hidden; }
    .fish-svg { width: 100%; max-width: 1000px; height: auto; }
    .spine { stroke: #475569; stroke-width: 6; stroke-linecap: round; }
    .rib { stroke: #64748b; stroke-width: 4; stroke-linecap: round; opacity: 0.5; transition: 0.3s; }
    .tail { fill: rgba(255, 130, 0, 0.1); stroke: #FF8200; stroke-width: 2; }
    .problem-box { fill: #dc3545; stroke: white; stroke-width: 2.5; }
    .problem-text { fill: white; font-weight: 800; font-size: 14px; text-anchor: middle; font-family: 'Inter', sans-serif; }
    .head-part { fill: #f8fafc; stroke: #cbd5e1; stroke-width: 2; transition: all 0.4s ease; }
    .fish-head-group:hover .lower-jaw { transform: rotate(20deg); transform-origin: 205px 200px; }
    .fish-head-group:hover .upper-head { transform: rotate(-8deg); transform-origin: 205px 200px; }
    .rib-group:hover .rib { stroke: #FF8200; opacity: 1; stroke-width: 6; }
    .rib-label { fill: white; font-weight: 800; font-size: 18px; font-family: 'Inter'; }
    .rib-sub { fill: #94a3b8; font-size: 12px; font-style: italic; }
    .why-container { background: rgba(255, 255, 255, 0.02); border: 1px solid rgba(255, 255, 255, 0.08); border-radius: 24px; padding: 2.5rem; transition: 0.3s ease; }
    .why-container:hover { border-color: var(--migros-orange); background: rgba(255, 255, 255, 0.04); }
    .why-steps { display: flex; flex-direction: column; gap: 1rem; }
    .why-item { font-size: 0.85rem; color: #94a3b8; padding: 1rem; background: rgba(255, 255, 255, 0.03); border-radius: 12px; position: relative; }
    .why-item strong { color: #f1f5f9; margin-right: 5px; }
    .root-cause { background: rgba(25, 135, 84, 0.15) !important; border: 1px solid rgba(25, 135, 84, 0.3); color: #34d399 !important; font-weight: 600; }
    .sipoc-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 15px;
}

.sipoc-column {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 20px;
    padding: 1.5rem 1rem;
    transition: all 0.3s ease;
}

.sipoc-column:hover {
    background: rgba(255, 255, 255, 0.04);
    border-color: rgba(255, 255, 255, 0.1);
    transform: translateY(-5px);
}

.process-column {
    background: rgba(255, 130, 0, 0.05);
    border: 1px solid rgba(255, 130, 0, 0.2);
}

.sipoc-col-header {
    text-align: center;
    font-family: 'JetBrains Mono', monospace;
    font-weight: 800;
    font-size: 1.1rem;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
}

.sipoc-item {
    background: rgba(255, 255, 255, 0.04);
    padding: 12px;
    border-radius: 10px;
    margin-bottom: 10px;
    font-size: 0.82rem;
    color: #cbd5e1;
    border-left: 3px solid transparent;
    transition: 0.2s;
}

.sipoc-column:nth-child(1) .sipoc-item { border-left-color: #ffc107; }
.sipoc-column:nth-child(2) .sipoc-item { border-left-color: #0dcaf0; }
.sipoc-column:nth-child(4) .sipoc-item { border-left-color: #198754; }
.sipoc-column:nth-child(5) .sipoc-item { border-left-color: #0d6efd; }

.sipoc-item:hover { background: rgba(255, 255, 255, 0.08); color: #fff; }

.sipoc-process-item {
    background: var(--migros-orange);
    color: white;
    text-align: center;
    font-weight: 700;
    font-size: 0.85rem;
    padding: 12px 10px;
    border-radius: 12px;
    margin-bottom: 4px;
    box-shadow: 0 4px 10px rgba(255, 130, 0, 0.3);
}

.sipoc-arrow {
    text-align: center;
    color: var(--migros-orange);
    font-size: 1.5rem;
    line-height: 1;
    margin-bottom: 4px;
}
</style>

<div class="container-fluid">
    
    <section id="sec-1" class="section-card">
        <div class="d-flex justify-content-between align-items-center mb-5">
            <div>
                <span class="badge-step">BÖLÜM I</span>
                <h2 class="section-title mt-3">Kurumsal Kimlik & Entegre Strateji Raporu</h2>
            </div>
            <img src="https://upload.wikimedia.org/wikipedia/tr/0/06/Migros_Logo.png" style="height: 50px; opacity: 0.9;">
        </div>
        
        <p class="text-muted mb-5">Bu rapor, Migros Ticaret A.Ş. için ayrı ayrı yürütülmüş dört stratejik analizi — SWOT, TOWS, MoSCoW ve RICE — tek bir karar çerçevesinde sentezlemektedir. Analizlerin merkezinde tek bir tema bulunmaktadır: <strong>Ürün kalitesi ve müşteri sağlığı.</strong></p>

        <div class="row g-4 mb-5">
            <div class="col-md-4">
                <div class="corporate-box h-100">
                    <h6 class="fw-bold mb-3"><i class="bi bi-database-check me-2 text-warning"></i>Veri Temeli</h6>
                    <p class="small mb-0">Raporumuz; Şikayetvar.com platformundan derlenen <strong>4.615 müşteri şikayeti</strong>, Türkiye perakende sektörü araştırmaları ve Migros kamuoyu beyanları üzerine inşa edilmiştir.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="corporate-box h-100">
                    <h6 class="fw-bold mb-3"><i class="bi bi-eye-fill me-2 text-warning"></i>Raporun Vizyonu</h6>
                    <p class="small text-muted mb-0">SWOT ile durumu tespit etmek, TOWS ile eyleme dönüştürmek, MoSCoW ile önceliklendirmek ve RICE ile bu aksiyonları nicel olarak (ROI) kanıtlamaktır.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="corporate-box h-100">
                    <h6 class="fw-bold mb-3"><i class="bi bi-shield-check me-2 text-warning"></i>Kritik Hedef</h6>
                    <p class="small text-muted mb-0">SKT geçmiş/bozuk ürün şikayetlerinin yarattığı "Çift Kırılganlık Döngüsünü" (W1+W2) kırarak %7.8 olan çözüm oranını artırmak.</p>
                </div>
            </div>
        </div>

        <div class="row row-cols-1 row-cols-md-4 g-5 text-center mt-5 justify-content-center">
            <div class="col team-member-card">
                <div class="team-photo-container"><img src="/images/user1.jpg" class="team-photo-large shadow-lg"></div>
                <h5 class="team-name mt-3">Ad Soyad</h5><div class="team-role-badge">Takım Lideri</div>
            </div>
            <div class="col team-member-card">
                <div class="team-photo-container"><img src="/images/user1.jpg" class="team-photo-large shadow-lg"></div>
                <h5 class="team-name mt-3">Ad Soyad</h5><div class="team-role-badge">Süreç Analisti</div>
            </div>
             <div class="col team-member-card">
                <div class="team-photo-container"><img src="/images/user1.jpg" class="team-photo-large shadow-lg"></div>
                <h5 class="team-name mt-3">Ad Soyad</h5><div class="team-role-badge">Veri Analisti</div>
            </div>
             <div class="col team-member-card">
                <div class="team-photo-container"><img src="/images/user1.jpg" class="team-photo-large shadow-lg"></div>
                <h5 class="team-name mt-3">Ad Soyad</h5><div class="team-role-badge">Kalite Yöneticisi</div>
            </div>
        </div>
    </section>

    <section id="sec-2" class="section-card">
        <div class="d-flex justify-content-between align-items-center mb-5">
            <div>
                <span class="badge-step">BÖLÜM II</span>
                <h2 class="section-title mt-3">01. SWOT Analizi: Çift Kırılganlık Tespiti</h2>
            </div>
            <div class="swot-score-badge"><i class="bi bi-award me-1"></i> Puan: 10</div>
        </div>
        
        <p class="text-muted mb-5">4.615 müşteri şikayeti ve pazar araştırmasına dayanan içsel-dışsal durum tespiti. Rapordaki <strong>"Çift Kırılganlık"</strong> (Yüksek Kalite Şikayeti + Düşük Çözüm Oranı) bu tablonun temel odak noktasıdır.</p>

        <div class="row g-5">
            <div class="col-md-6">
                <div class="swot-box-premium s-border">
                    <div class="swot-header">
                        <div class="swot-icon-circle bg-success-soft text-success"><i class="bi bi-lightning-charge-fill"></i></div>
                        <h5 class="fw-bold text-white mb-0">Güçlü Yönler (Strengths)</h5>
                    </div>
                    <ul class="sw-list-premium">
                        <li>70+ yıllık marka tarihi, kurumsal güven ve Lovemark ödülü.</li>
                        <li>3.720+ mağaza ile 81 ilde tam coğrafi kapsam.</li>
                        <li>Migros One entegre dijital ekosistemi ve iştirakleri (Taze Direkt vb.).</li>
                        <li>Her 2 müşteriden 1'inin üye olduğu Money sadakat programı.</li>
                    </ul>
                </div>
            </div>

            <div class="col-md-6">
                <div class="swot-box-premium w-border">
                    <div class="swot-header">
                        <div class="swot-icon-circle bg-danger-soft text-danger"><i class="bi bi-shield-slash-fill"></i></div>
                        <h5 class="fw-bold text-white mb-0">Zayıf Yönler (Weaknesses)</h5>
                    </div>
                    <ul class="sw-list-premium">
                        <li><strong>Kırılganlık 1:</strong> Ürün kalitesi şikayetlerinin toplam şikayete oranının %28,8 olması (SKT şikayetleri %7,4).</li>
                        <li><strong>Kırılganlık 2:</strong> Şikayet çözüm oranının yalnızca %7,8'de kalması.</li>
                        <li>Dijital-fiziksel kopukluk yaratan stok senkronizasyon hataları.</li>
                        <li>Personel tutum tutarsızlıkları (586 şikayet) ve kampanya güvenilirliği.</li>
                    </ul>
                </div>
            </div>

            <div class="col-md-6">
                <div class="swot-box-premium o-border">
                    <div class="swot-header">
                        <div class="swot-icon-circle bg-info-soft text-info"><i class="bi bi-rocket-takeoff-fill"></i></div>
                        <h5 class="fw-bold text-white mb-0">Fırsatlar (Opportunities)</h5>
                    </div>
                    <ul class="sw-list-premium">
                        <li>Tüketicilerde gıda güvenliğine artan hassasiyet ve organik/yerel ürün talebi.</li>
                        <li>%45'e ulaşan online market penetrasyonu ve 249 milyar TL'lik Q-ticaret pazarı.</li>
                        <li>AI destekli kalite ve stok yönetim teknolojilerine erişim.</li>
                        <li>Money verisiyle kişiselleştirilmiş müşteri deneyimi sunma fırsatı.</li>
                    </ul>
                </div>
            </div>

            <div class="col-md-6">
                <div class="swot-box-premium t-border">
                    <div class="swot-header">
                        <div class="swot-icon-circle bg-warning-soft text-warning"><i class="bi bi-exclamation-octagon-fill"></i></div>
                        <h5 class="fw-bold text-white mb-0">Tehditler (Threats)</h5>
                    </div>
                    <ul class="sw-list-premium">
                        <li>Şikayetvar/sosyal medya platformlarında viral itibar riski (Marka erozyonu).</li>
                        <li>BİM/A101 gibi rakiplerin agresif fiyat rekabeti ve Getir hızı.</li>
                        <li>Tarım Kredi Kooperatiflerinin taze ürün güveni konusundaki konumu.</li>
                        <li>Gıda güvenliği mevzuatlarının yasal olarak sıkılaşması.</li>
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <section id="sec-3" class="section-card">
        <div class="d-flex justify-content-between align-items-center mb-5">
            <div>
                <span class="badge-step">BÖLÜM III</span>
                <h2 class="section-title mt-3">02. TOWS Matrisi: Strateji Üretimi</h2>
            </div>
            <div class="swot-score-badge"><i class="bi bi-gear-wide-connected me-1"></i> Puan: 10</div>
        </div>

        <p class="text-muted mb-5">SWOT'un pasif durum tespitini eyleme dönüştüren aşama. Rapor analizine göre ürün kalitesi merkezli <strong>WT ve WO</strong> kategorileri en yüksek aciliyeti taşımaktadır.</p>

        <div class="row g-4">
            <div class="col-md-6">
                <div class="tows-card wo-border">
                    <div class="tows-header">
                        <span class="tows-tag bg-warning text-dark">WO Stratejileri</span>
                        <h6 class="fw-bold text-white mt-2">Fırsatlarla Zayıflıkları İyileştir</h6>
                    </div>
                    <ul class="sw-list-premium mt-3">
                        <li><strong>(WO-1) AI Destekli SKT/Kalite Kontrolü:</strong> %7,4 SKT şikayetini (W) Yapay zeka teknolojileriyle (O) RFID/barkod tabanlı otomatik uyarı sistemine dönüştürme.</li>
                        <li><strong>(WO-2) CRM Altyapısı Güçlendirme:</strong> %7,8'lik zayıf çözüm oranını (W), tüm kanalları birleştiren (Unified Inbox) ve 2-4 saat SLA veren yeni nesil CRM ile (O) çözme.</li>
                    </ul>
                </div>
            </div>

            <div class="col-md-6">
                <div class="tows-card wt-border">
                    <div class="tows-header">
                        <span class="tows-tag bg-danger text-white">WT Stratejileri</span>
                        <h6 class="fw-bold text-white mt-2">Zayıflıkları ve Tehditleri Minimize Et</h6>
                    </div>
                    <ul class="sw-list-premium mt-3">
                        <li><strong>(WT-1) Gıda Güvenliği Kriz Protokolü:</strong> Viral şikayet tehdidini (T), 2 saatlik müdahale SLA'sı ve anlık Şikayetvar/Sosyal Medya radar izlemesiyle engelleme.</li>
                        <li><strong>(WT-2) SKT Sıfır Tolerans Politikası:</strong> Sistematik açıklar ve yasal denetim (T) riskine karşı her mağazaya "SKT Sorumlusu" atama ve IoT sıcaklık sensörleri kurma.</li>
                    </ul>
                </div>
            </div>

            <div class="col-md-6">
                <div class="tows-card so-border">
                    <div class="tows-header">
                        <span class="tows-tag bg-success text-white">SO Stratejileri</span>
                        <h6 class="fw-bold text-white mt-2">Güçlü Yönlerle Fırsatları Yakala</h6>
                    </div>
                    <ul class="sw-list-premium mt-3">
                        <li><strong>(SO-1) Kalite Taahhüdü & Taze Garanti:</strong> 70 yıllık kurumsal güveni (S), gıda güvenliği hassasiyetine (O) bağlayarak "SKT geçmiş üründe otomatik para iadesi + Puan" kampanyası.</li>
                        <li><strong>(SO-4) Şeffaflık İletişimi:</strong> "Arkamızı Açıyoruz" kampanyası ve QR kodlu ürün tedarik zinciri izlenebilirliği sağlamak.</li>
                    </ul>
                </div>
            </div>

            <div class="col-md-6">
                <div class="tows-card st-border">
                    <div class="tows-header">
                        <span class="tows-tag bg-info text-white">ST Stratejileri</span>
                        <h6 class="fw-bold text-white mt-2">Güçlü Yönlerle Tehditleri Bertaraf Et</h6>
